# Browser-visible paths for the same-origin NoCodeBackend proxy.
VITE_AUTH_PROXY_URL=/api/ncb/auth
VITE_DATA_PROXY_URL=/api/ncb/data

# Server/runtime-only NoCodeBackend configuration. Do not expose these through VITE_*.
NCB_API_BASE_URL=https://your-nocodebackend-api.example.com
NCB_SECRET_KEY=your-server-only-secret-key
